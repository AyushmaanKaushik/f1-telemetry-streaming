{
  "datasets": [
    {
      "name": "driver_gaps",
      "displayName": "Live Driver Gaps",
      "query": "WITH latest_window AS (\n  SELECT MAX(window.end) AS max_ts\n  FROM f1_catalog.gold.gold_driver_gaps\n)\nSELECT\n  CONCAT('Car ', LPAD(CAST(g.car_index AS STRING), 2, '0')) AS car_label,\n  g.car_index,\n  ROUND(g.gap_to_leader_m, 1) AS gap_to_leader_m,\n  ROUND(g.segment_distance, 1) AS segment_distance_m\nFROM f1_catalog.gold.gold_driver_gaps g\nJOIN latest_window lw\n  ON g.window.end = lw.max_ts\nORDER BY g.gap_to_leader_m ASC"
    },
    {
      "name": "vehicle_health",
      "displayName": "Vehicle Health",
      "query": "WITH latest_window AS (\n  SELECT MAX(last_updated) AS max_ts\n  FROM f1_catalog.gold.gold_vehicle_health\n)\nSELECT\n  CONCAT('Car ', LPAD(CAST(h.car_index AS STRING), 2, '0')) AS car_label,\n  h.car_index,\n  ROUND(h.tyre_wear         , 1)       AS tyre_wear_pct,\n  ROUND(h.engine_wear       , 1)       AS engine_wear_pct,\n  ROUND(h.front_wing_damage , 1)       AS front_wing_pct,\n  ROUND(h.rear_wing_damage  , 1)       AS rear_wing_pct,\n  ROUND(h.fuel_in_tank,       2)       AS fuel_kg,\n  ROUND(h.ers_energy / 4000000.0 * 100 , 1)  AS ers_pct\nFROM (\n  SELECT\n    *,\n    ROW_NUMBER() OVER (PARTITION BY car_index ORDER BY last_updated DESC) AS rn\n  FROM f1_catalog.gold.gold_vehicle_health\n) h\nJOIN latest_window lw\n  ON h.last_updated = lw.max_ts\nWHERE h.rn = 1\nORDER BY h.car_index ASC"
    },
    {
      "name": "tyre_degradation",
      "displayName": "Tyre Degradation",
      "query": "SELECT\n  CONCAT('Car ', LPAD(CAST(car_index AS STRING), 2, '0'), ' (', COALESCE(MAX(tyre_compound), 'Unknown'), ')') AS car_label,\n  FLOOR(distance_traveled_m / 0.5) * 0.5 AS distance_bin_m,\n  ROUND(AVG(average_wear_pct), 2) AS avg_wear_pct\nFROM f1_catalog.gold.gold_tyre_degradation\nWHERE distance_traveled_m IS NOT NULL\n  AND average_wear_pct IS NOT NULL\nGROUP BY\n  car_index,\n  FLOOR(distance_traveled_m / 0.5) * 0.5\nORDER BY\n  car_index,\n  distance_bin_m"
    },
    {
      "name": "driver_speed",
      "displayName": "Driver Speed",
      "query": "WITH latest_window AS (\n  SELECT MAX(window.end) AS max_ts\n  FROM f1_catalog.gold.gold_distances\n)\nSELECT\n  CONCAT('Car ', LPAD(CAST(d.car_index AS STRING), 2, '0')) AS car_label,\n  ROUND(d.avg_speed, 0) AS speed_kmh\nFROM f1_catalog.gold.gold_distances d\nJOIN latest_window lw ON d.window.end = lw.max_ts\nGROUP BY d.car_index, d.avg_speed\nORDER BY speed_kmh DESC"
    }
  ],
  "pages": [
    {
      "name": "f1_main_page",
      "displayName": "F1 Live Telemetry",
      "layout": [
        {
          "widget": {
            "name": "car_filter",
